// Esquema de base de datos de ContentOS
// Convención: nombres de modelos y campos en español.
// Fase 0: núcleo multi-tenant (Organizacion, Usuario, Membresia).
// Fase 1: entidades de negocio (Cliente, Invitacion, EstrategiaDeMarca, Publicacion).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Roles posibles de un usuario dentro de una organización.
enum Rol {
  ADMIN
  COMMUNITY_MANAGER
  DISENADOR
  COPYWRITER
  ANALISTA
  CLIENTE
}

/// Estado comercial de un cliente (la marca) dentro de la agencia.
enum EstadoCliente {
  POTENCIAL
  ACTIVO
  PAUSADO
  ARCHIVADO
}

/// Tono de comunicación de una marca.
enum TonoComunicacion {
  FORMAL
  INFORMAL
  CASUAL
  PROFESIONAL
  CERCANO
  INSPIRADOR
  HUMORISTICO
}

/// Canal de publicación en redes sociales.
enum Canal {
  INSTAGRAM
  FACEBOOK
  TWITTER
  LINKEDIN
  TIKTOK
  YOUTUBE
  OTRO
}

/// Estado de vida de una publicación.
enum EstadoContenido {
  BORRADOR
  EN_REVISION
  APROBADO
  PROGRAMADO
  PUBLICADO
  RECHAZADO
}

/// Tipo de "botón" del Centro de IA que originó una generación.
/// Cada botón es un endpoint con salida estructurada (no chat).
enum TipoBotonIa {
  IDEAS_CONTENIDO
  COPYWRITING
  CARRUSEL
  HOOKS
  ESTRATEGIA_MENSUAL
  FODA
  BUYER_PERSONA
  PILARES
  CAMPANA
  ANALISIS_METRICAS
  OPORTUNIDADES
  OTRO
}

// ─── Fase 6: Notificaciones y planes ───

/// Plan comercial contratado por una organización. Define sus límites (marcas,
/// usuarios internos, cuota de IA) y qué funcionalidades tiene habilitadas.
/// PRUEBA es Agency completo por 14 días; al vencer cae a STARTER.
enum PlanSuscripcion {
  PRUEBA
  STARTER
  AGENCY
  AGENCY_PRO
  ENTERPRISE
}

/// Tipo de aviso del centro de notificaciones. Determina el ícono y el color en
/// el panel; el texto lo arma cada regla (o el evento que la emite).
/// Estado de un intento de pago de suscripción (Mercado Pago).
enum EstadoPago {
  PENDIENTE
  APROBADO
  RECHAZADO
}

enum TipoNotificacion {
  APROBACIONES_PENDIENTES
  PUBLICACION_APROBADA
  PUBLICACION_RECHAZADA
  DIAS_SIN_PUBLICAR
  CAMPANA_POR_TERMINAR
  TAREA_ASIGNADA
  INSTAGRAM_DESCONECTADO
  CUOTA_IA_CERCA
  CUOTA_IA_AGOTADA
}

// ─── Fase 3: Producción y Gestión de Archivos ───

/// Tipo de tarea dentro del flujo de producción de una publicación.
enum TipoTarea {
  REDACCION
  DISENO
  EDICION
  PROGRAMACION
  REVISION
  OTRO
}

/// Estado de avance de una tarea de producción.
enum EstadoTarea {
  PENDIENTE
  EN_CURSO
  BLOQUEADA
  HECHA
}

/// Naturaleza del archivo gestionado (la URL apunta al hosting externo).
enum TipoArchivo {
  IMAGEN
  VIDEO
  DOCUMENTO
  AUDIO
  OTRO
}

/// La agencia / equipo. Es el "tenant" del sistema: todo cuelga de acá.
model Organizacion {
  id            String              @id @default(cuid())
  nombre        String
  /// Plan contratado. Define límites y funcionalidades (ver `src/planes/`).
  plan          PlanSuscripcion     @default(PRUEBA)
  /// Vencimiento de la prueba gratuita. Al pasar, la organización cae a STARTER.
  planExpiraEn  DateTime?
  /// Suspendida por el superadmin (p. ej. falta de pago). Bloquea el acceso sin
  /// borrar nada. La levanta el mismo portal.
  suspendida    Boolean             @default(false)
  /// Overrides de los límites del plan (null = usar el del plan). Los pone el
  /// portal de superadministración para Enterprise o excepciones puntuales.
  limiteMarcas           Int?
  limiteUsuariosInternos Int?
  limiteGeneracionesIa   Int?
  /// Tope mensual de generaciones por persona, para que un solo miembro no se
  /// coma la cuota de toda la agencia. null = sin sub-límite.
  limiteIaPorUsuario     Int?
  creadoEn      DateTime            @default(now())
  actualizadoEn DateTime            @updatedAt
  membresias    Membresia[]
  clientes      Cliente[]
  invitaciones  Invitacion[]
  estrategias   EstrategiaDeMarca[]
  publicaciones Publicacion[]
  generacionesIa GeneracionIa[]
  tareas        Tarea[]
  archivos      Archivo[]
  metricas      MetricaPublicacion[]
  informes      Informe[]
  conexionesMeta ConexionMeta[]
  metricasCuenta MetricaCuenta[]
  notificaciones Notificacion[]
  consumosIa     ConsumoIa[]
  pagos          Pago[]

  @@map("organizaciones")
}

/// Usuario del sistema. Se sincroniza con Clerk a través de clerkId.
model Usuario {
  id            String      @id @default(cuid())
  clerkId       String      @unique
  email         String      @unique
  nombre        String?
  creadoEn      DateTime    @default(now())
  actualizadoEn DateTime    @updatedAt
  membresias    Membresia[]

  @@map("usuarios")
}

/// Relación Usuario ↔ Organizacion con un rol asociado.
/// Un usuario puede pertenecer a varias organizaciones con distinto rol.
model Membresia {
  id             String       @id @default(cuid())
  rol            Rol          @default(COMMUNITY_MANAGER)
  usuario        Usuario      @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  usuarioId      String
  organizacion   Organizacion @relation(fields: [organizacionId], references: [id], onDelete: Cascade)
  organizacionId String
  // Solo relevante cuando rol = CLIENTE: indica qué marca representa este miembro.
  cliente        Cliente?     @relation("ClienteMembresias", fields: [clienteId], references: [id], onDelete: SetNull)
  clienteId      String?
  tareasAsignadas Tarea[]
  notificaciones Notificacion[]
  creadoEn       DateTime     @default(now())
  actualizadoEn  DateTime     @updatedAt

  @@unique([usuarioId, organizacionId])
  @@index([organizacionId])
  @@index([clienteId])
  @@map("membresias")
}

/// Cliente = la marca que la agencia gestiona. Pertenece a una organización (tenant).
/// Modelo unificado: campos completos del slice masita + descripcion del slice capitán.
model Cliente {
  id                 String              @id @default(cuid())
  organizacion       Organizacion        @relation(fields: [organizacionId], references: [id], onDelete: Cascade)
  organizacionId     String
  nombre             String
  rubro              String?
  descripcion        String?             @db.Text
  ubicacion          String?
  sitioWeb           String?
  // Datos de contacto del referente de la marca.
  contactoNombre     String?
  contactoEmail      String?
  contactoTelefono   String?
  // Redes sociales como objeto { instagram, facebook, tiktok, linkedin, ... }.
  redes              Json?
  logoUrl            String?
  // Identidad visual: colores en formato hex (#RRGGBB).
  paletaColores      String[]
  tono               String?
  publicoObjetivo    String?
  productosServicios String?
  objetivos          String?
  competencia        String?
  promociones        String?
  estado             EstadoCliente       @default(ACTIVO)
  estrategias        EstrategiaDeMarca[]
  publicaciones      Publicacion[]
  archivos           Archivo[]
  membresias         Membresia[]         @relation("ClienteMembresias")
  invitaciones       Invitacion[]        @relation("ClienteInvitaciones")
  metricas           MetricaPublicacion[]
  informes           Informe[]
  conexionMeta       ConexionMeta?
  metricasCuenta     MetricaCuenta[]
  creadoEn           DateTime            @default(now())
  actualizadoEn      DateTime            @updatedAt

  @@index([organizacionId])
  @@map("clientes")
}

/// Invitación pendiente para sumar a alguien a la organización con un rol.
/// Cuando esa persona inicia sesión (su email coincide), se convierte en Membresia.
model Invitacion {
  id             String       @id @default(cuid())
  organizacion   Organizacion @relation(fields: [organizacionId], references: [id], onDelete: Cascade)
  organizacionId String
  email          String
  rol            Rol          @default(COMMUNITY_MANAGER)
  // Solo cuando rol = CLIENTE: marca que representará el invitado. Se copia a la
  // membresía al aplicar la invitación.
  cliente        Cliente?     @relation("ClienteInvitaciones", fields: [clienteId], references: [id], onDelete: SetNull)
  clienteId      String?
  creadoEn       DateTime     @default(now())

  @@unique([organizacionId, email])
  @@index([email])
  @@index([clienteId])
  @@map("invitaciones")
}

/// Estrategia de marca de un cliente: define tono, objetivo, pilares y público objetivo.
model EstrategiaDeMarca {
  id              String           @id @default(cuid())
  nombre          String
  objetivo        String           @db.Text
  publicoObjetivo String           @db.Text
  tono            TonoComunicacion @default(PROFESIONAL)
  pilares         String[]
  restricciones   String?          @db.Text
  cliente         Cliente          @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  clienteId       String
  organizacion    Organizacion     @relation(fields: [organizacionId], references: [id], onDelete: Cascade)
  organizacionId  String
  publicaciones   Publicacion[]
  creadoEn        DateTime         @default(now())
  actualizadoEn   DateTime         @updatedAt

  @@index([organizacionId])
  @@index([clienteId])
  @@map("estrategias_de_marca")
}

/// Publicación de contenido en una red social, asociada a una estrategia de marca.
model Publicacion {
  id              String            @id @default(cuid())
  titulo          String
  contenido       String            @db.Text
  imagenUrl       String?
  // ID del post real en Instagram/Facebook (cuando la publicación viene de Meta
  // o fue publicada desde acá). Sirve para traer después sus métricas.
  metaMediaId     String?
  // Momento en que se publicó de verdad en la red social.
  fechaPublicacion DateTime?
  // Tipo de medio en Instagram (FEED, REELS…). Permite filtrar métricas por
  // publicaciones vs reels.
  tipoMedioMeta   String?
  canal           Canal
  estado          EstadoContenido    @default(BORRADOR)
  motivoRechazo   String?            @db.Text
  fechaProgramada DateTime?
  // Una publicación siempre pertenece a un cliente; la estrategia es opcional.
  cliente         Cliente            @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  clienteId       String
  estrategia      EstrategiaDeMarca? @relation(fields: [estrategiaId], references: [id], onDelete: SetNull)
  estrategiaId    String?
  organizacion    Organizacion       @relation(fields: [organizacionId], references: [id], onDelete: Cascade)
  organizacionId  String
  tareas          Tarea[]
  archivos        Archivo[]
  metricas        MetricaPublicacion[]
  creadoEn        DateTime           @default(now())
  actualizadoEn   DateTime           @updatedAt

  @@index([organizacionId])
  @@index([clienteId])
  @@index([estrategiaId])
  @@index([fechaProgramada])
  @@index([estado])
  @@index([clienteId, metaMediaId])
  @@map("publicaciones")
}

/// Métricas de una publicación en una fecha (snapshot diario). Fase 4: las ingesta
/// la integración con Meta; el Dashboard por cliente y la IA de Métricas las leen.
/// Único por (publicacion, fecha) → re-ingestar el mismo día actualiza la fila.
model MetricaPublicacion {
  id             String       @id @default(cuid())
  organizacion   Organizacion @relation(fields: [organizacionId], references: [id], onDelete: Cascade)
  organizacionId String
  cliente        Cliente      @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  clienteId      String
  publicacion    Publicacion  @relation(fields: [publicacionId], references: [id], onDelete: Cascade)
  publicacionId  String
  canal          Canal
  fecha          DateTime     @db.Date
  impresiones    Int          @default(0)
  alcance        Int          @default(0)
  meGusta        Int          @default(0)
  comentarios    Int          @default(0)
  compartidos    Int          @default(0)
  guardados      Int          @default(0)
  clics          Int          @default(0)
  creadoEn       DateTime     @default(now())
  actualizadoEn  DateTime     @updatedAt

  @@unique([publicacionId, fecha])
  @@index([organizacionId])
  @@index([clienteId])
  @@index([fecha])
  @@map("metricas_publicacion")
}

/// Métricas diarias de la CUENTA de Instagram (no de una publicación). Instagram
/// sí expone serie diaria a nivel cuenta (~30 días hacia atrás), así que acá el
/// historial se puede traer de entrada. Único por (cliente, fecha).
model MetricaCuenta {
  id             String       @id @default(cuid())
  organizacion   Organizacion @relation(fields: [organizacionId], references: [id], onDelete: Cascade)
  organizacionId String
  cliente        Cliente      @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  clienteId      String
  fecha          DateTime     @db.Date
  // null = Instagram no expone esa métrica para esta cuenta (≠ de cero real).
  alcance        Int?
  vistas         Int?
  visitasPerfil  Int?
  seguidores     Int?
  creadoEn       DateTime     @default(now())
  actualizadoEn  DateTime     @updatedAt

  @@unique([clienteId, fecha])
  @@index([organizacionId])
  @@index([fecha])
  @@map("metricas_cuenta")
}

/// Conexión de un cliente (marca) con su cuenta de Instagram/Facebook vía Meta.
/// Guarda el token de la Página y la cuenta de Instagram Business vinculada, para
/// traer métricas reales. Un cliente tiene a lo sumo una conexión (1:1).
model ConexionMeta {
  id             String       @id @default(cuid())
  organizacion   Organizacion @relation(fields: [organizacionId], references: [id], onDelete: Cascade)
  organizacionId String
  cliente        Cliente      @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  clienteId      String       @unique
  // Página de Facebook (opcional; solo en el flujo clásico con Facebook Login).
  pageId         String?
  pageNombre     String?
  accessToken    String       @db.Text
  // Cuenta de Instagram Business asociada a esa Página.
  igUserId       String
  igUsername     String?
  tokenExpiraEn  DateTime?
  ultimaSync     DateTime?
  creadoEn       DateTime     @default(now())
  actualizadoEn  DateTime     @updatedAt

  @@index([organizacionId])
  @@map("conexiones_meta")
}

/// Traza de cada generación del Centro de IA: entrada, salida estructurada,
/// modelo y consumo de tokens (incluido el ahorro por prompt caching).
/// Es la base del Banco de Ideas y del control de costos de IA.
/// clienteId/estrategiaId se guardan sueltos (sin FK) para no acoplar dominios.
model GeneracionIa {
  id                  String       @id @default(cuid())
  organizacion        Organizacion @relation(fields: [organizacionId], references: [id], onDelete: Cascade)
  organizacionId      String
  /// Quién la pidió. Nullable porque las generaciones previas a la Fase 6 no lo
  /// registraban. Permite el detalle por persona y el sub-límite por usuario.
  usuarioId           String?
  clienteId           String?
  estrategiaId        String?
  tipoBoton           TipoBotonIa
  instruccion         String       @db.Text
  salida              Json
  modelo              String
  tokensEntrada       Int          @default(0)
  tokensSalida        Int          @default(0)
  tokensCacheCreacion Int          @default(0)
  tokensCacheLectura  Int          @default(0)
  creadoEn            DateTime     @default(now())

  @@index([organizacionId])
  @@index([clienteId])
  @@index([tipoBoton])
  // Para el detalle por persona y el sub-límite mensual por usuario.
  @@index([organizacionId, usuarioId, creadoEn])
  @@map("generaciones_ia")
}

/// Consumo de IA acumulado por organización y período (`YYYY-MM`).
///
/// Es un resumen redundante: el detalle está en `GeneracionIa`. Existe para que
/// verificar la cuota antes de cada generación sea **una sola lectura por clave**
/// y no una agregación sobre toda la tabla, que se degradaría con el uso.
model ConsumoIa {
  id                   String       @id @default(cuid())
  organizacion         Organizacion @relation(fields: [organizacionId], references: [id], onDelete: Cascade)
  organizacionId       String
  /// Formato `YYYY-MM` en UTC.
  periodo              String
  generaciones         Int          @default(0)
  tokensEntrada        Int          @default(0)
  tokensSalida         Int          @default(0)
  tokensCacheEscritura Int          @default(0)
  tokensCacheLectura   Int          @default(0)
  /// Costo acumulado en USD, con los precios vigentes al momento de cada llamada.
  costoUsd             Decimal      @default(0) @db.Decimal(12, 6)
  /// Cuándo se avisó que la cuota estaba por agotarse (para no repetir el aviso).
  avisadoEn            DateTime?
  creadoEn             DateTime     @default(now())
  actualizadoEn        DateTime     @updatedAt

  @@unique([organizacionId, periodo])
  @@index([periodo])
  @@map("consumos_ia")
}

/// Tarea de producción asociada a una publicación: el trabajo concreto que el
/// equipo debe hacer para llevar la pieza adelante (redactar, diseñar, revisar…).
/// Se asigna opcionalmente a una Membresia (un miembro de la organización).
model Tarea {
  id             String       @id @default(cuid())
  titulo         String
  descripcion    String?      @db.Text
  tipo           TipoTarea    @default(OTRO)
  estado         EstadoTarea  @default(PENDIENTE)
  fechaLimite    DateTime?
  publicacion    Publicacion  @relation(fields: [publicacionId], references: [id], onDelete: Cascade)
  publicacionId  String
  // Responsable de la tarea. Opcional hasta que se asigna.
  asignado       Membresia?   @relation(fields: [asignadoId], references: [id], onDelete: SetNull)
  asignadoId     String?
  organizacion   Organizacion @relation(fields: [organizacionId], references: [id], onDelete: Cascade)
  organizacionId String
  creadoEn       DateTime     @default(now())
  actualizadoEn  DateTime     @updatedAt

  @@index([organizacionId])
  @@index([publicacionId])
  @@index([asignadoId])
  @@index([estado])
  @@map("tareas")
}

/// Archivo gestionado de una marca (diseños, imágenes, documentos…). MVP: solo
/// metadata + URL al hosting externo (Render free no tiene disco persistente).
/// Cuelga de un Cliente y, opcionalmente, de una Publicacion concreta.
model Archivo {
  id             String       @id @default(cuid())
  nombre         String
  url            String
  tipo           TipoArchivo  @default(OTRO)
  tamanoBytes    Int?
  cliente        Cliente      @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  clienteId      String
  publicacion    Publicacion? @relation(fields: [publicacionId], references: [id], onDelete: SetNull)
  publicacionId  String?
  organizacion   Organizacion @relation(fields: [organizacionId], references: [id], onDelete: Cascade)
  organizacionId String
  creadoEn       DateTime     @default(now())
  actualizadoEn  DateTime     @updatedAt

  @@index([organizacionId])
  @@index([clienteId])
  @@index([publicacionId])
  @@map("archivos")
}

// ─── Fase 4: Informes y Automatizaciones ───

/// Informe mensual generado por IA para un cliente. Único por (clienteId, periodo).
model Informe {
  id              String       @id @default(cuid())
  periodo         String       // Formato YYYYMM, ej: "202606"
  resumenMetricas Json
  analisisIa      Json
  generacionIaId  String?
  cliente         Cliente      @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  clienteId       String
  organizacion    Organizacion @relation(fields: [organizacionId], references: [id], onDelete: Cascade)
  organizacionId  String
  creadoEn        DateTime     @default(now())
  actualizadoEn   DateTime     @updatedAt

  @@unique([clienteId, periodo])
  @@index([organizacionId])
  @@index([clienteId])
  @@index([periodo])
  @@map("informes")
}

/// Aviso dirigido a un miembro concreto de una organización.
///
/// Se crea de dos maneras (ver `src/notificaciones/`):
///  - **por evento**: alguien aprueba una publicación → se emite en el acto;
///  - **por regla**: el job diario evalúa reglas y emite lo que corresponda.
///
/// `clave` es lo que evita que el job repita el mismo aviso todos los días: si el
/// destinatario ya tiene uno **sin leer** con esa misma clave, se actualiza en vez
/// de crear otro (así "tenés 3 pendientes" pasa a "tenés 5" sin duplicar la fila).
model Notificacion {
  id             String           @id @default(cuid())
  organizacion   Organizacion     @relation(fields: [organizacionId], references: [id], onDelete: Cascade)
  organizacionId String
  destinatario   Membresia        @relation(fields: [membresiaId], references: [id], onDelete: Cascade)
  membresiaId    String
  tipo           TipoNotificacion
  clave          String
  titulo         String
  cuerpo         String?          @db.Text
  /// Ruta del front a la que lleva el aviso (ej. "/aprobaciones").
  enlace         String?
  leida          Boolean          @default(false)
  leidaEn        DateTime?
  creadoEn       DateTime         @default(now())
  actualizadoEn  DateTime         @updatedAt

  @@index([organizacionId])
  @@index([membresiaId, leida, creadoEn])
  @@index([membresiaId, clave, leida])
  @@map("notificaciones")
}

/// Intento de pago de una suscripción vía Mercado Pago (Checkout Pro).
///
/// Se crea al iniciar el checkout (PENDIENTE) y lo actualiza el webhook cuando
/// MP confirma. Al quedar APROBADO se activa el plan de la organización. Se
/// conserva como historial de facturación.
model Pago {
  id             String          @id @default(cuid())
  organizacion   Organizacion    @relation(fields: [organizacionId], references: [id], onDelete: Cascade)
  organizacionId String
  plan           PlanSuscripcion
  /// Monto y moneda tal como se cobraron (ver `planes/precios-plan.ts`).
  monto          Decimal         @db.Decimal(12, 2)
  moneda         String
  estado         EstadoPago      @default(PENDIENTE)
  /// Referencia que viaja a MP y vuelve en el webhook (external_reference).
  referencia     String          @unique
  /// Id del pago en Mercado Pago, cuando se confirma.
  mpPagoId       String?
  creadoEn       DateTime        @default(now())
  actualizadoEn  DateTime        @updatedAt

  @@index([organizacionId])
  @@map("pagos")
}

/// Registro de auditoría del portal de superadministración: qué superadmin hizo
/// qué y sobre qué organización. El portal rompe el aislamiento multi-tenant a
/// propósito, así que toda acción queda trazada.
model AuditoriaAdmin {
  id             String   @id @default(cuid())
  /// Email del superadmin que ejecutó la acción (de la lista SUPERADMINS).
  superadmin     String
  /// Qué hizo: CAMBIAR_PLAN, AJUSTAR_LIMITES, REINICIAR_CUOTA, SUSPENDER, REACTIVAR.
  accion         String
  /// Organización afectada (no es FK: se conserva aunque la organización se borre).
  organizacionId String
  /// Detalle libre de lo que cambió (valores antes/después).
  detalle        Json?
  creadoEn       DateTime @default(now())

  @@index([organizacionId])
  @@index([superadmin])
  @@map("auditoria_admin")
}

/// Log de ejecuciones de jobs automáticos (publicar programadas, generar informes).
model EjecucionJob {
  id          String   @id @default(cuid())
  tipo        String
  resultado   Json
  ejecutadoEn DateTime @default(now())

  @@index([tipo])
  @@map("ejecuciones_job")
}
