// Esquema de base de datos de ContentOS
// Convención: nombres de modelos y campos en español.
// En Fase 0 solo definimos el núcleo multi-tenant: Organizacion, Usuario, Membresia.
// Las entidades de negocio (Cliente, EstrategiaDeMarca, Publicacion, etc.) se agregan en Fase 1.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Roles posibles de un usuario dentro de una organización.
enum Rol {
  ADMIN
  COMMUNITY_MANAGER
  DISENADOR
  COPYWRITER
  ANALISTA
  CLIENTE
}

/// Estado comercial de un cliente (la marca) dentro de la agencia.
enum EstadoCliente {
  POTENCIAL
  ACTIVO
  PAUSADO
  ARCHIVADO
}

/// La agencia / equipo. Es el "tenant" del sistema: todo cuelga de acá.
model Organizacion {
  id          String       @id @default(cuid())
  nombre      String
  creadoEn    DateTime     @default(now())
  actualizadoEn DateTime   @updatedAt
  membresias  Membresia[]
  clientes    Cliente[]
  invitaciones Invitacion[]

  @@map("organizaciones")
}

/// Usuario del sistema. Se sincroniza con Clerk a través de clerkId.
model Usuario {
  id            String      @id @default(cuid())
  clerkId       String      @unique
  email         String      @unique
  nombre        String?
  creadoEn      DateTime    @default(now())
  actualizadoEn DateTime    @updatedAt
  membresias    Membresia[]

  @@map("usuarios")
}

/// Relación Usuario ↔ Organizacion con un rol asociado.
/// Un usuario puede pertenecer a varias organizaciones con distinto rol.
model Membresia {
  id             String       @id @default(cuid())
  rol            Rol          @default(COMMUNITY_MANAGER)
  usuario        Usuario      @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  usuarioId      String
  organizacion   Organizacion @relation(fields: [organizacionId], references: [id], onDelete: Cascade)
  organizacionId String
  creadoEn       DateTime     @default(now())
  actualizadoEn  DateTime     @updatedAt

  @@unique([usuarioId, organizacionId])
  @@index([organizacionId])
  @@map("membresias")
}

/// Cliente = la marca que la agencia gestiona. Pertenece a una organización (tenant).
/// Capitan agrega aquí las relaciones a EstrategiaDeMarca y Publicacion en su slice.
model Cliente {
  id                 String        @id @default(cuid())
  organizacion       Organizacion  @relation(fields: [organizacionId], references: [id], onDelete: Cascade)
  organizacionId     String
  nombre             String
  rubro              String?
  ubicacion          String?
  sitioWeb           String?
  // Datos de contacto del referente de la marca.
  contactoNombre     String?
  contactoEmail      String?
  contactoTelefono   String?
  // Redes sociales como objeto { instagram, facebook, tiktok, linkedin, ... }.
  redes              Json?
  logoUrl            String?
  // Identidad visual: colores en formato hex (#RRGGBB).
  paletaColores      String[]
  tono               String?
  publicoObjetivo    String?
  productosServicios String?
  objetivos          String?
  competencia        String?
  promociones        String?
  estado             EstadoCliente @default(ACTIVO)
  creadoEn           DateTime      @default(now())
  actualizadoEn      DateTime      @updatedAt

  @@index([organizacionId])
  @@map("clientes")
}

/// Invitación pendiente para sumar a alguien a la organización con un rol.
/// Cuando esa persona inicia sesión (su email coincide), se convierte en Membresia.
model Invitacion {
  id             String       @id @default(cuid())
  organizacion   Organizacion @relation(fields: [organizacionId], references: [id], onDelete: Cascade)
  organizacionId String
  email          String
  rol            Rol          @default(COMMUNITY_MANAGER)
  creadoEn       DateTime     @default(now())

  @@unique([organizacionId, email])
  @@index([email])
  @@map("invitaciones")
}
