# Base de datos PostgreSQL (coincide con docker-compose.yml)
DATABASE_URL="postgresql://contentos:contentos@localhost:5432/contentos?schema=public"

# Puerto del servidor NestJS
PUERTO=3000

# Origen permitido para CORS (el frontend)
ORIGEN_FRONTEND="http://localhost:5173"

# Clerk — autenticación (https://dashboard.clerk.com → API Keys)
# El backend solo necesita validar el JWT, por eso usa el dominio de las JWKS y el issuer.
CLERK_JWKS_URL="https://<tu-subdominio>.clerk.accounts.dev/.well-known/jwks.json"
CLERK_ISSUER="https://<tu-subdominio>.clerk.accounts.dev"
# Opcional: clave secreta de Clerk para llamadas al backend de Clerk (invitaciones, etc.)
CLERK_SECRET_KEY=""

# Anthropic — Claude API (se usa recién en Fase 2)
ANTHROPIC_API_KEY=""
# Modelo por defecto del módulo de IA
MODELO_IA="claude-opus-4-8"

# Meta — Instagram Login API (integración de métricas, Fase 4).
# Identificador y clave secreta de la app de INSTAGRAM (no los de Facebook):
# App → API de Instagram → Configuración de la API con inicio de sesión de Instagram.
META_IG_APP_ID=""
META_IG_APP_SECRET=""
META_REDIRECT_URI="https://localhost:3000/api/meta/callback"

# Cloudinary — subida de archivos multimedia (Fase 5 #5)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
# Poner en "true" recién cuando la app de Meta tenga habilitado el permiso
# instagram_business_content_publish (si no, el login falla con Invalid Scopes).
META_PUBLICAR_HABILITADO="false"

# Portal de superadministración: emails autorizados, separados por coma.
SUPERADMINS="masita@ejemplo.com,capitan@ejemplo.com"

# Pagos con Mercado Pago (Sprint 3). Access Token de tu app de MP.
MERCADOPAGO_ACCESS_TOKEN=""
MONEDA_PAGO="ARS"
URL_BACKEND="https://contentos-backend-0qns.onrender.com"
