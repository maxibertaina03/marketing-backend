# Base de datos PostgreSQL (coincide con docker-compose.yml)
DATABASE_URL="postgresql://contentos:contentos@localhost:5432/contentos?schema=public"

# Puerto del servidor NestJS
PUERTO=3000

# Origen permitido para CORS (el frontend)
ORIGEN_FRONTEND="http://localhost:5173"

# Clerk — autenticación (https://dashboard.clerk.com → API Keys)
# El backend solo necesita validar el JWT, por eso usa el dominio de las JWKS y el issuer.
CLERK_JWKS_URL="https://<tu-subdominio>.clerk.accounts.dev/.well-known/jwks.json"
CLERK_ISSUER="https://<tu-subdominio>.clerk.accounts.dev"
# Opcional: clave secreta de Clerk para llamadas al backend de Clerk (invitaciones, etc.)
CLERK_SECRET_KEY=""

# Anthropic — Claude API (se usa recién en Fase 2)
ANTHROPIC_API_KEY=""
# Modelo por defecto del módulo de IA
MODELO_IA="claude-opus-4-8"
